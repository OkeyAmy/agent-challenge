# =============================================================
# Nosana × ElizaOS Relay Agent — Environment Variables
# =============================================================
# cp .env.example .env  then fill in your values

# -------------------------------------------------------------
# LLM — Qwen/Qwen3.5-4B via Nosana Inference Endpoint
# -------------------------------------------------------------
OPENAI_API_KEY=nosana
# OPENAI_API_URL  — read by plugin-nosana-llm (project-local plugin)
# OPENAI_BASE_URL — read by @elizaos/plugin-openai (set both to be safe)
OPENAI_API_URL=https://4ksj3tve5bazqwkuyqdhwdpcar4yutcuxphwhckrdxmu.node.k8s.prd.nos.ci/v1
OPENAI_BASE_URL=https://4ksj3tve5bazqwkuyqdhwdpcar4yutcuxphwhckrdxmu.node.k8s.prd.nos.ci/v1
# MODEL_NAME / LARGE_MODEL — read by plugin-nosana-llm / plugin-openai respectively
MODEL_NAME=Qwen/Qwen3.5-4B
LARGE_MODEL=Qwen/Qwen3.5-4B

# -------------------------------------------------------------
# Embedding — Qwen3-Embedding-0.6B via Nosana
# -------------------------------------------------------------
OPENAI_EMBEDDING_URL=https://4yiccatpyxx773jtewo5ccwhw1s2hezq5pehndb6fcfq.node.k8s.prd.nos.ci/v1
OPENAI_EMBEDDING_API_KEY=nosana
OPENAI_EMBEDDING_MODEL=Qwen3-Embedding-0.6B
OPENAI_EMBEDDING_DIMENSIONS=1024

# Option B: Local development with Ollama
# OPENAI_API_KEY=ollama
# OPENAI_API_URL=http://127.0.0.1:11434/v1
# MODEL_NAME=qwen3.5:27b

# -------------------------------------------------------------
# ElizaOS Agent Server
# -------------------------------------------------------------
SERVER_PORT=3000

# -------------------------------------------------------------
# PostgreSQL — relay event store
# -------------------------------------------------------------
# Format: postgres://user:password@host:port/database
# The relay plugin creates a `relay` schema and its tables automatically.
# This DB is shared — other projects can query relay.events directly.
#
DATABASE_URL=postgres://postgres:password@localhost:5432/relay_db

# -------------------------------------------------------------
# Relay REST API
# -------------------------------------------------------------
RELAY_PORT=3890
RELAY_LOG_DIR=./relay/logs
RELAY_SESSION_STATE=./relay/relay-session-state.json
RELAY_MAX_LOG_SIZE_MB=10
RELAY_MAX_LOG_FILES=5

# -------------------------------------------------------------
# Notion Integration (optional — Notion sync disabled if not set)
# -------------------------------------------------------------
# 1. Create a Notion integration: https://www.notion.so/my-integrations
# 2. Share a page with the integration and copy its ID from the URL
#
# NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_SYNC_INTERVAL_MS=30000

# -------------------------------------------------------------
# Telegram Ticker (optional — disabled by default)
# -------------------------------------------------------------
# Create a bot via @BotFather, add it to a group, get the chat ID
#
# TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_CHAT_ID=-100xxxxxxxxxx
# TELEGRAM_TICKER_ENABLED=false
