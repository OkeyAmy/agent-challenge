# ============================================================
# Forge — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ============================================================

# ----------------------------------------------------------
# Model — OpenAI-compatible API
# ----------------------------------------------------------
# The model identifier understood by your API endpoint.
FORGE_MODEL=your-model-name

# Base URL of an OpenAI-compatible completions endpoint.
# Examples:
#   OpenAI:   https://api.openai.com/v1
#   Local:    http://localhost:11434/v1
#   Other:    https://your-provider.example.com/v1/openai
FORGE_BASE_URL=https://your-provider.example.com/v1/openai

# API key for the above endpoint.
FORGE_API_KEY=your-api-key-here

# ----------------------------------------------------------
# Logging (optional)
# ----------------------------------------------------------
# Tracing filter for the forge binary.
# Valid values: error | warn | info | debug | trace
RUST_LOG=forge=info

# ----------------------------------------------------------
# Docker (optional — only needed when running via docker-compose)
# ----------------------------------------------------------
# GID of the docker group on the host, so the forge container
# can write to /var/run/docker.sock.
# Find it with: getent group docker | cut -d: -f3
DOCKER_GID=999
